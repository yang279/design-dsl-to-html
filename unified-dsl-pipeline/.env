# ── 全局配置 ───────────────────────────────────────

# 主服务端口
PORT=3104

# 默认运行模式
DEFAULT_MODE=ipc

# ── Icon Agent 配置 ───────────────────────────────────
# 图标解析服务（DeepSeek API）
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
HF_ENDPOINT=https://hf-mirror.com

# ── Component Service 配置 ────────────────────────────
# 组件匹配服务（DeepSeek API）
DASHSCOPE_API_KEY=sk-your-deepseek-key-here
MODEL=deepseek-v4-flash
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_TIMEOUT_MS=60000
LLM_LOG_IO=false

# ── DSL to Hex 配置 ───────────────────────────────────
# WASM 路径（默认自动检测）
# WASM_PATH=./packages/dsl-to-hex/bin/dsl_to_hex.wasm

# 组件库根目录（三个服务共用）
# LIB_OUT_DIR=/path/to/lib-out
# HEX_LIB_DIR=/path/to/lib-out

# ── 日志级别 ────────────────────────────────────────
LOG_LEVEL=info